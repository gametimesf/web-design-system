      padding: var(--spacing-05);
    }

    .toast-stack {
      left: var(--spacing-05);
      position: static;
      right: auto;
      top: auto;
      width: 100%;
    }

    .toast-preview {
      min-height: 0;
    }

    .dialog-footer {
      flex-wrap: wrap;
    }

    .tab-bar {
      flex-wrap: wrap;
    }
