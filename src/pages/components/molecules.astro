</style>

<script>
  const toastRoot = document.querySelector('.toast-preview');

  if (toastRoot) {
    toastRoot.addEventListener('click', (event) => {
      const target = event.target;

      if (!(target instanceof HTMLElement)) {
        return;
      }

      if (target.classList.contains('toast-dismiss')) {
        const toast = target.closest('.toast');
        if (toast instanceof HTMLElement) {
          toast.hidden = true;
        }
      }

      if (target.classList.contains('reset-toasts')) {
        const toasts = toastRoot.querySelectorAll('.toast');
        toasts.forEach((toast) => {
          if (toast instanceof HTMLElement) {
            toast.hidden = false;
          }
        });
      }
    });
  }
</script>
