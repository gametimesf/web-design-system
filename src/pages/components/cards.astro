---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="cards | Gametime Design System"
  description="CollectionCard, CMSContentCard, ValuePropCard, and LoginCard patterns based on Gametime." 
>
  <section class="page-header">
    <h1>Cards</h1>
    <p>Collection, content, value props, and login card patterns used across Gametime surfaces.</p>
  </section>

  <section class="doc-section">
    <div class="section-heading">
      <h2>Collection Card (Event)</h2>
      <p>Carousel card with image, event metadata, and pricing.</p>
    </div>

    <div class="collection-grid">
      <article class="collection-card">
        <div class="collection-image">
          <button class="favorite-btn" type="button" aria-label="Save event">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="12" fill="var(--color-black-900)" fill-opacity="0.5" />
              <g transform="translate(4, 4)">
                <path
