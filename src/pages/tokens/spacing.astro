---
import Layout from '../../layouts/Layout.astro';

const spacingTokens = [
  { name: '--spacing--03', value: -4 },
  { name: '--spacing--02', value: -2 },
  { name: '--spacing--01', value: -1 },
  { name: '--spacing-01', value: 2 },
  { name: '--spacing-02', value: 4 },
  { name: '--spacing-03', value: 8 },
  { name: '--spacing-04', value: 12 },
  { name: '--spacing-05', value: 16 },
  { name: '--spacing-06', value: 20 },
  { name: '--spacing-07', value: 24 },
  { name: '--spacing-08', value: 32 },
  { name: '--spacing-09', value: 40 },
  { name: '--spacing-10', value: 48 },
  { name: '--spacing-11', value: 56 },
  { name: '--spacing-12', value: 64 },
  { name: '--spacing-13', value: 80 },
  { name: '--spacing-14', value: 96 },
  { name: '--spacing-15', value: 160 },
];

const spacingGroups = [
  {
    id: 'micro',
    label: 'Micro',
    range: '01–03',
    description: 'Icon padding, tight inline gaps, and hairline separation.',
    tokens: ['--spacing-01', '--spacing-02', '--spacing-03'],
  },
  {
    id: 'compact',
    label: 'Compact',
    range: '04–06',
    description: 'Dense lists, compact cards, and small form controls.',
    tokens: ['--spacing-04', '--spacing-05', '--spacing-06'],
  },
  {
    id: 'comfortable',
    label: 'Comfortable',
    range: '07–09',
    description: 'Default layout rhythm for content blocks and sections.',
    tokens: ['--spacing-07', '--spacing-08', '--spacing-09'],
  },
  {
    id: 'spacious',
    label: 'Spacious',
    range: '10–15',
    description: 'Hero spacing, page gutters, and large section breaks.',
    tokens: [
      '--spacing-10',
      '--spacing-11',
      '--spacing-12',
      '--spacing-13',
      '--spacing-14',
      '--spacing-15',
    ],
  },
];

const negativeTokens = spacingTokens.filter((token) => token.value < 0);
const tokenMap = new Map(spacingTokens.map((token) => [token.name, token]));
---

<Layout title="Spacing | Gametime Design System" description="Spacing token documentation.">
  <header class="page-header">
    <div>
      <p class="eyebrow">Tokens</p>
      <h1>Spacing</h1>
      <p class="subtitle">
        The spacing scale drives rhythm across layouts, components, and content. Use positive
        tokens for padding, margins, and gaps. Negative tokens are reserved for optical alignment
        and intentional overlap.
      </p>
    </div>
    <div class="scale-summary">
      <div>
        <span class="summary-label">Positive Steps</span>
        <span class="summary-value">15</span>
      </div>
      <div>
        <span class="summary-label">Negative Steps</span>
        <span class="summary-value">3</span>
      </div>
    </div>
  </header>

  <section class="token-table" aria-labelledby="spacing-scale">
    <div class="section-header">
      <h2 id="spacing-scale">Spacing scale</h2>
      <p>Each bar renders at the exact pixel value of its token.</p>
    </div>
    <div class="token-row token-row--header">
      <span>Token</span>
      <span>Value</span>
      <span>Scale</span>
    </div>
    {spacingTokens.map((token) => (
      <div class={`token-row ${token.value < 0 ? 'token-row--negative' : ''}`}>
        <span class="token-name">{token.name}</span>
        <span class="token-value">{token.value}px</span>
        <span class="token-bar" style={`--bar-size: ${Math.abs(token.value)}px;`}>
          <span class="bar-track">
            <span class="bar-fill" aria-hidden="true"></span>
          </span>
        </span>
      </div>
    ))}
  </section>

  <section class="grouped-scale" aria-labelledby="spacing-groups">
    <div class="section-header">
      <h2 id="spacing-groups">Usage groups</h2>
      <p>Positive steps are grouped by intended use to keep layout rhythm consistent.</p>
    </div>
    <div class="group-grid">
      {spacingGroups.map((group) => (
        <article class="group-card">
          <header>
            <h3>{group.label}</h3>
            <span class="group-range">{group.range}</span>
          </header>
          <p>{group.description}</p>
          <div class="group-list">
            {group.tokens.map((name) => {
              const token = tokenMap.get(name);
              if (!token) return null;
              return (
                <div class="group-token">
                  <span>{token.name}</span>
                  <span>{token.value}px</span>
                  <span class="group-bar" style={`--bar-size: ${token.value}px;`}>
                    <span class="bar-fill" aria-hidden="true"></span>
                  </span>
                </div>
              );
            })}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="examples" aria-labelledby="spacing-examples">
    <div class="section-header">
      <h2 id="spacing-examples">Practical examples</h2>
      <p>Spacing tokens applied to padding, margin, and layout gaps.</p>
    </div>
    <div class="example-grid">
      <article class="example-card">
        <div class="example-preview padding-example">
          <div class="padding-surface">
            <div class="padding-content">Card padding — `--spacing-06`</div>
          </div>
        </div>
        <div class="example-meta">
          <h3>Padding</h3>
          <p>Use consistent interior padding to reinforce hierarchy.</p>
        </div>
      </article>
      <article class="example-card">
        <div class="example-preview margin-example">
          <div class="margin-stack">
            <div class="margin-item">Item A</div>
            <div class="margin-item">Item B</div>
            <div class="margin-item">Item C</div>
          </div>
        </div>
        <div class="example-meta">
          <h3>Vertical rhythm</h3>
          <p>`--spacing-04` used as margin between stacked elements.</p>
        </div>
      </article>
      <article class="example-card">
        <div class="example-preview gap-example">
          <div class="chip-row">
            <span class="chip">Label</span>
            <span class="chip">Status</span>
            <span class="chip">Action</span>
          </div>
        </div>
        <div class="example-meta">
          <h3>Layout gaps</h3>
          <p>Flex gaps keep related UI elements aligned without manual margins.</p>
        </div>
      </article>
    </div>
  </section>

  <section class="negative-scale" aria-labelledby="spacing-negative">
    <div class="section-header">
      <h2 id="spacing-negative">Negative steps</h2>
      <p>Use sparingly for optical alignment or overlap.</p>
    </div>
    <div class="negative-grid">
      {negativeTokens.map((token) => (
        <div class="negative-card">
          <div class="negative-preview" style={`--bar-size: ${Math.abs(token.value)}px;`}>
            <span class="bar-fill" aria-hidden="true"></span>
          </div>
          <div>
            <p class="token-name">{token.name}</p>
            <p class="token-value">{token.value}px</p>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-08);
    margin-bottom: var(--spacing-10);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: var(--font-size-100);
    color: var(--theme-light-text-default-tertiary);
  }

  h1 {
    font-size: clamp(2rem, 2vw + 1.5rem, 3rem);
    margin: var(--spacing-03) 0 var(--spacing-04);
  }

  .subtitle {
    max-width: 560px;
    color: var(--theme-light-text-default-secondary);
    font-size: var(--font-size-300);
  }

  .scale-summary {
    display: grid;
    gap: var(--spacing-05);
    padding: var(--spacing-06);
    background: var(--color-white-1000);
    border-radius: var(--radius-l);
    border: 1px solid var(--theme-light-border-default-secondary);
    min-width: 200px;
    box-shadow: var(--elevation-1);
  }

  .summary-label {
    display: block;
    font-size: var(--font-size-100);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--theme-light-text-default-tertiary);
  }

  .summary-value {
    font-size: var(--font-size-500);
    font-weight: var(--font-weight-semibold);
    color: var(--theme-light-text-default-primary);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--spacing-06);
    margin-bottom: var(--spacing-06);
  }

  section {
    margin-bottom: var(--spacing-12);
  }

  .token-table {
    background: var(--color-white-1000);
    padding: var(--spacing-08);
    border-radius: var(--radius-l);
    border: 1px solid var(--theme-light-border-default-secondary);
    box-shadow: var(--elevation-1);
  }

  .token-row {
    display: grid;
    grid-template-columns: 160px 80px 1fr;
    gap: var(--spacing-06);
    align-items: center;
    padding: var(--spacing-03) 0;
    border-bottom: 1px solid var(--theme-light-border-default-secondary);
  }

  .token-row--header {
    font-size: var(--font-size-100);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--theme-light-text-default-tertiary);
  }

  .token-row:last-child {
    border-bottom: none;
  }

  .token-row--negative .token-value {
    color: var(--theme-light-text-danger-primary);
    font-weight: var(--font-weight-semibold);
  }

  .token-name {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-200);
  }

  .token-bar {
    width: 100%;
  }

  .bar-track {
    display: flex;
    align-items: center;
    width: 100%;
    height: 10px;
    background: var(--color-brand-gray-100);
    border-radius: var(--radius-full);
    overflow: hidden;
    position: relative;
  }

  .token-row--negative .bar-track {
    justify-content: flex-end;
    background: var(--color-red-050);
  }

  .bar-fill {
    display: block;
    height: 100%;
    width: var(--bar-size);
    background: var(--color-brand-green-500);
    border-radius: var(--radius-full);
  }

  .token-row--negative .bar-fill {
    background: var(--color-red-500);
  }

  .grouped-scale .group-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--spacing-06);
  }

  .group-card {
    background: var(--color-white-1000);
    border-radius: var(--radius-l);
    border: 1px solid var(--theme-light-border-default-secondary);
    padding: var(--spacing-06);
    display: grid;
    gap: var(--spacing-04);
    box-shadow: var(--elevation-1);
  }

  .group-card header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .group-range {
    font-size: var(--font-size-100);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--theme-light-text-default-tertiary);
  }

  .group-list {
    display: grid;
    gap: var(--spacing-03);
  }

  .group-token {
    display: grid;
    grid-template-columns: 1fr auto 80px;
    gap: var(--spacing-03);
    align-items: center;
    font-size: var(--font-size-200);
  }

  .group-bar {
    height: 8px;
    background: var(--color-brand-gray-100);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .group-bar .bar-fill {
    height: 100%;
  }

  .examples .example-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--spacing-06);
  }

  .example-card {
    background: var(--color-white-1000);
    border-radius: var(--radius-l);
    border: 1px solid var(--theme-light-border-default-secondary);
    padding: var(--spacing-06);
    display: grid;
    gap: var(--spacing-05);
    box-shadow: var(--elevation-1);
  }

  .example-preview {
    background: var(--color-brand-gray-050);
    border-radius: var(--radius-m);
    padding: var(--spacing-05);
  }

  .padding-example .padding-surface {
    background: var(--color-brand-green-050);
    padding: var(--spacing-06);
    border-radius: var(--radius-m);
    border: 1px dashed var(--color-brand-green-400);
  }

  .padding-content {
    background: var(--color-white-1000);
    padding: var(--spacing-03);
    border-radius: var(--radius-s);
    border: 1px solid var(--theme-light-border-default-secondary);
  }

  .margin-stack {
    display: grid;
    gap: var(--spacing-04);
  }

  .margin-item {
    background: var(--color-white-1000);
    border-radius: var(--radius-s);
    padding: var(--spacing-03) var(--spacing-04);
    border: 1px solid var(--theme-light-border-default-secondary);
  }

  .chip-row {
    display: flex;
    gap: var(--spacing-03);
    flex-wrap: wrap;
  }

  .chip {
    background: var(--color-brand-gray-900);
    color: var(--color-white-1000);
    padding: var(--spacing-02) var(--spacing-04);
    border-radius: var(--radius-full);
    font-size: var(--font-size-200);
  }

  .negative-scale .negative-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-06);
  }

  .negative-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-05);
    background: var(--color-white-1000);
    border-radius: var(--radius-l);
    border: 1px solid var(--theme-light-border-default-secondary);
    padding: var(--spacing-05);
    box-shadow: var(--elevation-1);
  }

  .negative-preview {
    width: 100px;
    height: 10px;
    background: var(--color-red-050);
    border-radius: var(--radius-full);
    overflow: hidden;
    display: flex;
    justify-content: flex-end;
  }

  .negative-preview .bar-fill {
    width: var(--bar-size);
    background: var(--color-red-500);
  }

  @media (max-width: 900px) {
    .page-header {
      flex-direction: column;
    }

    .scale-summary {
      width: 100%;
    }

    .token-row {
      grid-template-columns: 1fr 80px 1fr;
    }
  }
</style>
