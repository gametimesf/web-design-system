---

<Layout
  title="Colors | Gametime Design System"
  description="Color primitives and semantic theme tokens for the Gametime design system."
>
  <div class="colors-page">
    <header class="page-hero">
      <p class="kicker">Tokens</p>
      <h1>Colors</h1>
      <p>
        Visual inventory of color primitives, semantic light/dark tokens, and partner
        colors. All values are pulled from CSS custom properties.
      </p>
    </header>

    <section class="section" aria-labelledby="color-primitives">
      <div class="section-header">
        <h2 id="color-primitives">Color Primitives</h2>
        <p>
          Base palettes used to compose semantic tokens. Brand Gray and Brand Green are
          the primary palettes.
        </p>
      </div>

      <div class="palette-list">
        {palettes.map((palette) => (
          <article
            class={`palette ${palette.primary ? 'primary' : ''}`}
            data-palette={palette.name}
          >
            <div class="palette-header">
              <h3>{palette.label}</h3>
              {palette.primary ? <span class="badge">Primary</span> : null}
            </div>
            <div class="swatch-row">
              {palette.steps.map((step) => {
                const varName = `--color-${palette.name}-${step}`;
                return (
                  <div class="swatch" data-color={varName} style={`background: var(${varName});`}>
                    <span class="swatch-step">{step}</span>
                    <span class="swatch-value" data-var={varName}></span>
                  </div>
                );
              })}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="semantic-tokens">
      <div class="section-header">
        <h2 id="semantic-tokens">Semantic Theme Tokens</h2>
        <p>
          Light and dark theme tokens grouped by usage category. Each swatch is mapped
          to its resolved color value.
        </p>
      </div>

      <div class="semantic-grid">
        {semanticGroups.map((group) => (
          <article class="semantic-group">
            <h3>{group.title}</h3>
            <div class="token-list">
              {group.tokens.map((token) => (
                <div class="token-row">
                  <span class="token-swatch" style={`background: var(${token});`}></span>
                  <span class="token-name">{token}</span>
                  <span class="token-value" data-var={token}></span>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section" aria-labelledby="partner-colors">
      <div class="section-header">
        <h2 id="partner-colors">Partner Colors</h2>
        <p>Partner brand colors surfaced alongside the core palettes.</p>
      </div>

      <div class="partner-grid">
        {partnerTokens.map((partner) => (
          <div class="partner-card">
            <div class="partner-swatch" style={`background: var(${partner.varName});`}></div>
            <div class="partner-meta">
              <h3>{partner.name}</h3>
              <p class="partner-token">{partner.varName}</p>
              <p class="partner-value" data-var={partner.varName}></p>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>

<script>
  const resolveCustomProperty = (element, name, depth = 0) => {
    const value = getComputedStyle(element).getPropertyValue(name).trim();
    if (!value) return '';
    if (value.startsWith('var(') && depth < 6) {
      const inner = value.slice(4, -1).split(',')[0].trim();
      return resolveCustomProperty(element, inner, depth + 1);
    }
    return value;
  };

  const parseHex = (hex) => {
    const cleaned = hex.replace('#', '').trim();
    if (![3, 4, 6, 8].includes(cleaned.length)) return null;
    if (cleaned.length <= 4) {
      const r = parseInt(cleaned[0] + cleaned[0], 16);
      const g = parseInt(cleaned[1] + cleaned[1], 16);
      const b = parseInt(cleaned[2] + cleaned[2], 16);
      const a = cleaned.length === 4 ? parseInt(cleaned[3] + cleaned[3], 16) / 255 : 1;
      return { r, g, b, a };
    }
    const r = parseInt(cleaned.slice(0, 2), 16);
    const g = parseInt(cleaned.slice(2, 4), 16);
    const b = parseInt(cleaned.slice(4, 6), 16);
    const a = cleaned.length === 8 ? parseInt(cleaned.slice(6, 8), 16) / 255 : 1;
    return { r, g, b, a };
  };

  const parseRgb = (value) => {
    const match = value
      .replace(/\s+/g, '')
      .match(/^rgba?\((\d+),(\d+),(\d+)(?:,(\d*\.?\d+))?\)$/i);
    if (!match) return null;
    return {
      r: Number(match[1]),
      g: Number(match[2]),
      b: Number(match[3]),
      a: match[4] ? Number(match[4]) : 1,
    };
  };

  const getLuminance = ({ r, g, b, a }) => {
    const toLinear = (channel) => {
      const value = channel / 255;
      return value <= 0.03928 ? value / 12.92 : Math.pow((value + 0.055) / 1.055, 2.4);
    };
    const lum = 0.2126 * toLinear(r) + 0.7152 * toLinear(g) + 0.0722 * toLinear(b);
    return a < 1 ? lum * a + (1 - a) : lum;
  };

  const getContrastColor = (value) => {
    const parsed = value.startsWith('#') ? parseHex(value) : parseRgb(value);
    if (!parsed) return 'var(--color-setlist-black-1000)';
    const luminance = getLuminance(parsed);
    return luminance > 0.6 ? 'var(--color-setlist-black-1000)' : 'var(--color-white-1000)';
  };

  document.querySelectorAll('[data-var]').forEach((el) => {
    const varName = el.getAttribute('data-var');
    if (!varName) return;
    const value = resolveCustomProperty(el, varName);
    if (value) {
      el.textContent = value;
    }
  });

  document.querySelectorAll('[data-color]').forEach((el) => {
    const varName = el.getAttribute('data-color');
    if (!varName) return;
    const value = resolveCustomProperty(el, varName);
    if (!value) return;
    el.style.setProperty('--swatch-ink', getContrastColor(value));
  });
</script>

<style>
  .colors-page {
    display: grid;
    gap: var(--spacing-10);
    --partner-affirm: var(--color-purple-500);
  }

  .page-hero {
    max-width: 720px;
  }

  .kicker {
    color: var(--color-brand-green-700);
    font-size: var(--font-size-100);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-03);
  }

  .page-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    margin-bottom: var(--spacing-04);
  }

  .page-hero p {
    font-size: var(--font-size-300);
  }

  .section {
    display: grid;
    gap: var(--spacing-06);
  }

  .section-header {
    max-width: 640px;
  }

  .section-header h2 {
    font-size: var(--font-size-600);
    margin-bottom: var(--spacing-02);
  }

  .palette-list {
    display: grid;
    gap: var(--spacing-06);
  }

  .palette {
    background: var(--color-white-1000);
    border: 1px solid var(--theme-border-primary);
    border-radius: var(--radius-m);
    box-shadow: var(--elevation-1);
    padding: var(--spacing-05);
  }

  .palette.primary {
    border-color: var(--color-brand-green-300);
    box-shadow: 0 0 0 1px var(--color-brand-green-200), var(--elevation-1);
  }

  .palette-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-03);
    margin-bottom: var(--spacing-04);
  }

  .palette-header h3 {
    font-size: var(--font-size-400);
  }

  .badge {
    font-size: var(--font-size-100);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-green-800);
    background: var(--color-brand-green-050);
    padding: var(--spacing-01) var(--spacing-03);
    border-radius: var(--radius-full);
    border: 1px solid var(--color-brand-green-200);
  }

  .swatch-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--spacing-03);
  }

  .swatch {
    min-height: 86px;
    border-radius: var(--radius-s);
    padding: var(--spacing-03);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--swatch-ink, var(--color-setlist-black-1000));
    border: 1px solid transparent;
  }

  .palette[data-palette='white'] .swatch {
    border-color: var(--color-brand-gray-200);
  }

  .palette[data-palette='black'] .swatch {
    border-color: var(--color-brand-gray-300);
  }

  .swatch-step {
    font-size: var(--font-size-100);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .swatch-value {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-100);
  }

  .semantic-grid {
    display: grid;
    gap: var(--spacing-06);
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .semantic-group {
    background: var(--color-white-1000);
    border: 1px solid var(--theme-border-primary);
    border-radius: var(--radius-m);
    padding: var(--spacing-05);
    box-shadow: var(--elevation-1);
  }

  .semantic-group h3 {
    margin-bottom: var(--spacing-04);
    font-size: var(--font-size-300);
  }

  .token-list {
    display: grid;
    gap: var(--spacing-03);
  }

  .token-row {
    display: grid;
    grid-template-columns: 22px minmax(0, 1fr) auto;
    gap: var(--spacing-03);
    align-items: center;
    font-size: var(--font-size-100);
    padding: var(--spacing-02);
    border-radius: var(--radius-s);
    background: var(--color-brand-gray-050);
  }

  .token-swatch {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    border: 1px solid var(--color-brand-gray-200);
  }

  .token-name {
    font-family: var(--font-family-mono);
    color: var(--color-brand-gray-700);
  }

  .token-value {
    font-family: var(--font-family-mono);
    color: var(--color-brand-gray-600);
  }

  .partner-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-05);
  }

  .partner-card {
    display: flex;
    gap: var(--spacing-04);
    align-items: center;
    background: var(--color-white-1000);
    border: 1px solid var(--theme-border-primary);
    border-radius: var(--radius-m);
    padding: var(--spacing-05);
    box-shadow: var(--elevation-1);
  }

  .partner-swatch {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-m);
    border: 1px solid var(--color-brand-gray-200);
  }

  .partner-meta h3 {
    margin-bottom: var(--spacing-02);
  }

  .partner-token,
  .partner-value {
    font-family: var(--font-family-mono);
    font-size: var(--font-size-100);
    color: var(--color-brand-gray-600);
  }

  @media (max-width: 900px) {
    .swatch-row {
      grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    }

    .token-row {
      grid-template-columns: 20px minmax(0, 1fr);
    }

    .token-value {
      grid-column: 2 / -1;
    }
  }
</style>
